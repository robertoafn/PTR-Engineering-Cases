{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ptr/cases/case_metadata.schema.json",
  "title": "Case Metadata",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "phenomenon",
    "objective",
    "authors",
    "created_at",
    "version",
    "license_code",
    "license_docs",
    "software_stack",
    "inputs",
    "outputs",
    "qc_rules",
    "validation",
    "traceability",
    "si_units",
    "status"
  ],
  "properties": {
    "case_id":    { "type": "string", "pattern": "^[0-9]{3}_[a-z0-9_]+$" },
    "title":      { "type": "string", "minLength": 5 },
    "phenomenon": { "type": "string" },
    "objective":  { "type": "string" },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":  { "type": "string" },
          "orcid": { "type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$" },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "created_at":   { "type": "string", "format": "date-time" },
    "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "license_code": { "type": "string" },
    "license_docs": { "type": "string" },
    "software_stack": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "license"],
        "properties": {
          "name":    { "type": "string" },
          "version": { "type": "string" },
          "license": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },
    "inputs":   { "type": "array" },
    "outputs":  { "type": "array" },
    "qc_rules": { "type": "array", "items": { "type": "string" } },
    "validation": {
      "type": "object",
      "required": ["strategy", "acceptance_criteria"],
      "properties": {
        "strategy":            { "type": "string" },
        "acceptance_criteria": { "type": "string" }
      }
    },
    "traceability": {
      "type": "object",
      "required": ["provenance_ref"],
      "properties": {
        "provenance_ref": { "type": "string" },
        "derived_from":   { "type": "array" }
      }
    },
    "si_units": { "type": "boolean", "const": true },
    "status":   { "enum": ["draft", "review", "validated", "published"] }
  },
  "additionalProperties": false
}
